  <system.webServer>
    <defaultDocument>
      <files>
        <add value="LOGINPAGE.aspx"/>
      </files>
    </defaultDocument>
    <!--<security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="1073741824" />
      </requestFiltering>
    </security>-->
  </system.webServer>
  <system.serviceModel>
    <bindings/>
    <client/>
  </system.serviceModel>
  <system.data>
